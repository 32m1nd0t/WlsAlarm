<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:paddingBottom="24dp">

        <!-- ── 기본 정보 카드 ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:text="기본 정보"
                    android:textColor="#3F51B5"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="이름 (예: 혈압약)">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:hint="설명 (선택)">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etDesc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── 요일 선택 카드 ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="알림 요일"
                    android:textColor="#3F51B5"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ToggleButton
                        android:id="@+id/btnMon"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="2dp"
                        android:background="@drawable/bg_day_toggle"
                        android:textColor="@color/chip_day_text"
                        android:textOn="월"
                        android:textOff="월"
                        android:checked="true"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <ToggleButton
                        android:id="@+id/btnTue"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="2dp"
                        android:background="@drawable/bg_day_toggle"
                        android:textColor="@color/chip_day_text"
                        android:textOn="화"
                        android:textOff="화"
                        android:checked="true"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <ToggleButton
                        android:id="@+id/btnWed"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="2dp"
                        android:background="@drawable/bg_day_toggle"
                        android:textColor="@color/chip_day_text"
                        android:textOn="수"
                        android:textOff="수"
                        android:checked="true"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <ToggleButton
                        android:id="@+id/btnThu"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="2dp"
                        android:background="@drawable/bg_day_toggle"
                        android:textColor="@color/chip_day_text"
                        android:textOn="목"
                        android:textOff="목"
                        android:checked="true"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <ToggleButton
                        android:id="@+id/btnFri"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="2dp"
                        android:background="@drawable/bg_day_toggle"
                        android:textColor="@color/chip_day_text"
                        android:textOn="금"
                        android:textOff="금"
                        android:checked="true"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <ToggleButton
                        android:id="@+id/btnSat"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="2dp"
                        android:background="@drawable/bg_day_toggle"
                        android:textColor="@color/chip_day_text"
                        android:textOn="토"
                        android:textOff="토"
                        android:checked="true"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <ToggleButton
                        android:id="@+id/btnSun"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="2dp"
                        android:background="@drawable/bg_day_toggle"
                        android:textColor="@color/chip_day_text"
                        android:textOn="일"
                        android:textOff="일"
                        android:checked="true"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── 시간 선택 카드 ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="알림 시간"
                    android:textColor="#3F51B5"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <NumberPicker
                        android:id="@+id/npHour"
                        android:layout_width="72dp"
                        android:layout_height="wrap_content" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=":"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:layout_marginHorizontal="8dp"
                        android:textColor="#333333" />

                    <NumberPicker
                        android:id="@+id/npMinute"
                        android:layout_width="72dp"
                        android:layout_height="wrap_content" />

                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddTime"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="+ 이 시간 추가" />

                <!-- 추가된 시간 영역 (없으면 숨김) -->
                <TextView
                    android:id="@+id/tvAddedLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="4dp"
                    android:text="추가된 시간"
                    android:textSize="12sp"
                    android:textColor="#888888"
                    android:visibility="gone" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/timeChipsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── 저장 버튼 ── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:textSize="16sp"
            android:text="저장" />

    </LinearLayout>
</ScrollView>
